SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Use sqlite:///./test.db for local development with no setup,
# or a real postgresql:// URL for production/shared environments.
DATABASE_URL=sqlite:///./test.db

# Leave both blank to run on keyword-only detection (no external
# calls). Get VirusTotal key: virustotal.com -> profile -> API key.
# Get Safe Browsing key: Google Cloud Console -> enable Safe
# Browsing API -> create an API key under Credentials.
VIRUSTOTAL_API_KEY=
GOOGLE_SAFE_BROWSING_API_KEY=

# Seconds to wait for each external API before giving up
EXTERNAL_API_TIMEOUT=5
